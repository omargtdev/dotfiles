{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
        "model": "opencode-go/kimi-k2.6",
        "fallback_models": [
            "opencode-go/kimi-k2.7-code",
            "opencode-go/glm-5.2",
            "opencode-go/glm-5.1",
            "opencode/big-pickle"
        ]
    },
    // GPT-only
    // "hephaestus": {
    //     "model": "opencode/gpt-5.5", 
    //     "fallback_models": [
    //         "opencode-go/deepseek-v4-pro",
    //         "opencode-go/kimi-k2.7-code",
    //         "opencode-go/qwen3.7-max"
    //     ],
    //     "allow_non_gpt_model": true
    // },
    "prometheus": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/kimi-k2.7-code",
            "opencode-go/kimi-k2.6"
        ]
    },
    "atlas": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/kimi-k2.7-code",
        "opencode-go/minimax-m3",
        "opencode-go/minimax-m2.7"
      ]
    },

    // Subagents
    "oracle": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/qwen3.7-max",
            "opencode-go/minimax-m3"
        ]
    },
    "librarian": {
        "model": "opencode-go/qwen3.6-plus",
        "fallback_models": [
            "opencode-go/minimax-m3",
            "opencode-go/minimax-m2.7"
        ]
    },
    "explore": {
        "model": "opencode-go/qwen3.6-plus",
        "fallback_models": [
            "opencode-go/minimax-m3",
            "opencode-go/minimax-m2.7"
        ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/glm-5.2",
        "opencode-go/glm-5.1"
      ]
    },
    "metis": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/kimi-k2.6",
            "opencode-go/qwen3.7-max"
        ]
    },
    "momus": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/qwen3.7-max"
        ]
    },
    "sisyphus-junior": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/minimax-m3",
        "opencode-go/minimax-m2.7",
        "opencode-go/qwen3.7-max"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/kimi-k2.6",
            "opencode-go/qwen3.7-max",
            "opencode-go/qwen3.7-plus"
        ]
    },
    "ultrabrain": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/qwen3.7-max",
            "opencode-go/minimax-m3"
        ]
    },
    "deep": { // Recommend GPT
        "model": "opencode-go/deepseek-v4-pro",
        "fallback_models": [
            "opencode-go/kimi-k2.7-code",
            "opencode-go/qwen3.7-max"
        ]
    },
    "artistry": {
        "model": "opencode-go/mimo-v2.5-pro",
        "fallback_models": [
            "opencode-go/glm-5.2",
            "opencode-go/qwen3.7-max",
            "opencode-go/mimo-v2.5"
        ]
    },
    "quick": {
        "model": "opencode-go/minimax-m3",
        "fallback_models": [
            "opencode-go/minimax-m2.7",
            "opencode-go/deepseek-v4-flash",
            "opencode-go/deepseek-v4-flash-free"
        ]
    },
    "unspecified-low": {
        "model": "opencode-go/kimi-k2.6",
        "fallback_models": [
            "opencode-go/minimax-m3",
            "opencode-go/minimax-m2.7"
        ]
    },
    "unspecified-high": {
        "model": "opencode-go/glm-5.2",
        "fallback_models": [
            "opencode-go/glm-5.1",
            "opencode-go/kimi-k2.7-code",
            "opencode-go/kimi-k2.6"
        ]
    },
    "writing": {
        "model": "opencode-go/kimi-k2.7-code",
        "fallback_models": [
            "opencode-go/kimi-k2.6",
            "opencode-go/minimax-m3",
            "opencode-go/minimax-m2.7",
            "opencode-go/qwen3.7-plus"
        ]
    }
  }
}
